{
  "name": "habee",
  "version": "0.1.0",
  "description": "Desktop AI agreement app for multi-model discussion.",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": [
    "electron",
    "lit",
    "ai",
    "agreement"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@rollup/rollup-win32-x64-msvc": "^4.61.1",
    "ai": "^6.0.204",
    "lit": "^3.2.1",
    "marked": "^18.0.5",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.habee.app",
    "productName": "Habee",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
